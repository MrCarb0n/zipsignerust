# .gitignore
/dist/
/target/
Cargo.lock
# Personal / Dev scripts
build.sh
key.sh
certs/
.claude/
AGENTS.md
CLAUDE.md
# Tooling artifacts (regenerated by graphify / MCP server)
graphify-out/
.gitnexus/
# gitnexus MCP writes a literal-name `${HOME}/` directory in cwd on every
# invocation. The leading backslash escapes the first char so git does
# not treat it as a shell-style glob and the `$` survives.
\${HOME}/
# In-place backup artifacts from `--inplace` signing
*.bak
# Local release notes generated by build.sh
release_notes.md
